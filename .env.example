# ============================================
# RuralShiksha Environment Configuration
# ============================================
# Copy this file to .env and update with your values

# ============================================
# Django Configuration
# ============================================
DEBUG=False
SECRET_KEY=your-super-secret-key-change-in-production
ENVIRONMENT=production

# ============================================
# Database Configuration
# ============================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=ruralsiksha
DB_USER=ruralsiksha_user
DB_PASSWORD=your-secure-db-password
DB_HOST=db
DB_PORT=5432

# ============================================
# Security Configuration
# ============================================
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=604800

# ============================================
# Celery Configuration
# ============================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TIMEZONE=UTC

# ============================================
# Cache Configuration
# ============================================
CACHE_URL=redis://redis:6379/1

# ============================================
# AI Tutor (Ollama) Configuration
# ============================================
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.7

# ============================================
# SMS Notifications (Fast2SMS)
# ============================================
FAST2SMS_API_KEY=your-fast2sms-api-key
FAST2SMS_ROUTE=otp
SMS_SENDER_ID=RURALK

# ============================================
# Email Configuration
# ============================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@ruralsiksha.com

# ============================================
# Frontend Configuration
# ============================================
VITE_API_URL=http://localhost:8000/api
VITE_APP_NAME=RuralShiksha
VITE_ENVIRONMENT=development

# ============================================
# File Upload Configuration
# ============================================
FILE_UPLOAD_MAX_MEMORY_SIZE=52428800
DATA_UPLOAD_MAX_MEMORY_SIZE=52428800
MEDIA_ROOT=/app/media
MEDIA_URL=/media/
STATIC_ROOT=/app/staticfiles
STATIC_URL=/static/

# ============================================
# Time Configuration
# ============================================
TIME_ZONE=UTC
USE_TZ=True
LANGUAGE_CODE=en-us
